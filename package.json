{
  "name": "@animetosho/parpar",
  "version": "0.4.5",
  "description": "High performance multi-threaded PAR2 creation library",
  "keywords": [
    "par2",
    "par2cmdline",
    "par2create",
    "parchive",
    "parity",
    "error-correcting-codes",
    "erasure-coding",
    "ecc",
    "reed-solomon"
  ],
  "license": "CC0-1.0",
  "author": "Anime Tosho",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/animetosho/parpar.git"
  },
  "main": "lib/parpar.js",
  "bin": "bin/parpar.js",
  "engines": {
    "node": ">=0.10"
  },
  "scripts": {
    "preinstall": "node scripts/prebuild-check.js",
    "install": "node-gyp rebuild && bash scripts/postbuild-patchelf.sh",
    "test": "cd test && for f in *.js; do node --openssl-legacy-provider \"$f\" || exit 1; done",
    "test:par3-dispatch": "node test/par3-method-dispatch.js",
    "test:e2e": "for f in test/e2e-*.js; do node --openssl-legacy-provider \"$f\" || exit 1; done",
    "prepare": "husky"
  },
  "type": "commonjs",
  "pkg": {
    "assets": "help*.txt"
  },
  "gypfile": true,
  "dependencies": {
    "async": "0.2.0 - 2.9999.9999",
    "blake3": "^2.1.7"
  },
  "bugs": {
    "url": "https://github.com/animetosho/parpar/issues"
  },
  "homepage": "https://animetosho.org/app/parpar",
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
